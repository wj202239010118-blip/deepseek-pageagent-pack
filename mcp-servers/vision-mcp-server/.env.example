# Vision MCP Server Configuration
# Copy this file to .env and modify as needed

# Required: OpenAI-compatible API base URL
VISION_BASE_URL=http://localhost:8000/v1/chat/completions

# Required: Model name
VISION_MODEL=Qwen3-VL-32B

# Optional: API key (leave empty if not required)
VISION_API_KEY=

# Optional: Generation parameters
VISION_MAX_TOKENS=4096
VISION_TEMPERATURE=0.7
