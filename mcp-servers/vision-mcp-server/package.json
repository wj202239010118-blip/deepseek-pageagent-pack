{
  "name": "vision-mcp-server",
  "version": "1.0.0",
  "description": "MCP server providing multimodal vision capabilities via OpenAI-compatible API endpoints (Qwen3-VL, GPT-4o, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vision-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "vision",
    "multimodal",
    "qwen3-vl",
    "openai-compatible",
    "claude-code",
    "image-analysis",
    "ocr",
    "video-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
