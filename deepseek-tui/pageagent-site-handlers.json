{
  "_description": "Page Agent site handlers — adapted from Qshot siteHandlers.json for Page Agent MCP browser tools",
  "_usage": "Load this file via rlm_open or reference as static knowledge for multi-AI search workflows",
  "_version": "1.0",
  "_source": "https://github.com/30bewater/Qshot",

  "ai_sites": [
    {
      "id": "chatgpt",
      "name": "ChatGPT",
      "url": "https://chatgpt.com/",
      "login_required": true,
      "dom_hints": {
        "input_selectors": ["#prompt-textarea", "div[contenteditable='true']", "textarea"],
        "submit_selectors": [
          "button[data-testid='send-button']",
          "button[aria-label*='Send']",
          "button[aria-label*='Submit']",
          "button[aria-label*='发送']"
        ]
      },
      "page_agent_sequence": [
        {"tool": "browser_open_tab", "args": {"url": "https://chatgpt.com/"}},
        {"tool": "browser_get_map", "note": "Locate input index and send button index"},
        {"tool": "browser_type", "note": "Type query into the contenteditable div or textarea"},
        {"tool": "browser_click", "note": "Click send button"},
        {"tool": "wait", "note": "6-15 seconds for response, cold start may need 20s"}
      ],
      "quirks": "Cold start hydration is slow; submit button may be aria-disabled briefly. Use sendKeys Enter as fallback."
    },
    {
      "id": "claude",
      "name": "Claude",
      "url": "https://claude.ai/",
      "login_required": true,
      "dom_hints": {
        "input_selectors": ["div[contenteditable='true'].ProseMirror", "div[contenteditable='true']"],
        "submit_selectors": [
          "button[aria-label*='Send']",
          "button[aria-label*='Submit']",
          "button[type='submit']"
        ]
      },
      "page_agent_sequence": [
        {"tool": "browser_open_tab", "args": {"url": "https://claude.ai/"}},
        {"tool": "browser_get_map", "note": "Locate ProseMirror div and send button"},
        {"tool": "browser_type", "note": "Type query into contenteditable div"},
        {"tool": "browser_click", "note": "Click send button"}
      ],
      "quirks": "ProseMirror editor needs contenteditable div. Response may take 10-30 seconds."
    },
