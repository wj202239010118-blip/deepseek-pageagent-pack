  "site_groups": {
    "overseas": ["chatgpt", "claude", "gemini", "grok", "perplexity"],
    "domestic": ["deepseek", "kimi", "doubao", "qwen", "yuanbao", "metaso"],
    "all_ai": ["chatgpt", "claude", "gemini", "deepseek", "kimi", "grok", "doubao", "qwen", "yuanbao", "metaso", "perplexity"],
    "fast_compare": ["chatgpt", "claude", "gemini", "deepseek"],
    "chinese_focused": ["deepseek", "kimi", "doubao", "qwen", "yuanbao"]
  },

  "multi_round_template": {
    "_description": "Template for multi-round deep deliberation across AI sites",
    "rounds": [
      {
        "round": 1,
        "name": "Seed",
        "action": "Send the core question to ALL target AIs simultaneously",
        "collect": "Gather all responses, extract key claims and approaches"
      },
      {
        "round": 2,
        "name": "Probe",
        "action": "For EACH AI: craft a follow-up question based on their specific response. Challenge assumptions, ask for concrete examples, or request deeper analysis",
        "collect": "Gather deepened responses from each AI"
      },
      {
        "round": 3,
        "name": "Cross-Examine",
        "action": "Send AI-A's Round 2 response to AI-B, asking: 'Another AI suggested this approach. Do you agree? What would you add or challenge?' Repeat cross-wise for top 3-4 AIs",
        "collect": "Gather cross-examination responses, noting agreements and rebuttals"
      },
      {
        "round": "final",
        "name": "Synthesize",
        "action": "Compile all responses from all rounds. Identify: 1) Consensus points, 2) Unique insights, 3) Key disagreements and reasoning. Present unified recommendation with confidence levels and trade-offs."
      }
    ]
  }
}
